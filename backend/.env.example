# Database (default: SQLite for local dev, use PostgreSQL for production)
INFORM_DATABASE_URL=sqlite:///./inform.db
# INFORM_DATABASE_URL=postgresql://user:pass@host:5432/inform

# CORS origins (comma-separated, include your Vercel domain in production)
INFORM_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# External APIs
INFORM_POSTCODES_IO_URL=https://api.postcodes.io
INFORM_NHS_STATS_BASE_URL=https://www.england.nhs.uk/statistics/wp-content/uploads/sites/2
